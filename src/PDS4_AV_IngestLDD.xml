  <DD_Attribute>
    <name>container_type</name>
    <version_id>1.0</version_id>
    <local_identifier>container_type</local_identifier>
    <nillable_flag>false</nillable_flag>
    <submitter_name>Rafael Alanis</submitter_name>
    <definition>Specifies the type (format) of the container in PDS terms.
    </definition>
    <DD_Value_Domain>
      <enumeration_flag>true</enumeration_flag>
      <value_data_type>ASCII_Short_String_Preserved</value_data_type>
      <unit_of_measure_type>Units_of_None</unit_of_measure_type>
      <DD_Permissible_Value>
        <value>MP4</value>
        <value_meaning>MPEG-4 Part 14 file, can contain audio and/or video</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>M4A</value>
        <value_meaning>MPEG-4 Audio-only file</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>None</value>
        <value_meaning>No container, e.g. WAV files typically do not have an explicit container</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Other</value>
        <value_meaning>Non-PDS-compliant container type (should not be used except for Product_External)</value_meaning>
      </DD_Permissible_Value>
    </DD_Value_Domain>
  </DD_Attribute>

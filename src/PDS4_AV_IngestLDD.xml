  <DD_Attribute>
    <name>handler_class</name>
    <version_id>1.0</version_id>
    <local_identifier>handler_class</local_identifier>
    <nillable_flag>false</nillable_flag>
    <submitter_name>Rafael Alanis</submitter_name>
    <definition>Defines the high-level functional role of a track, whether it is actual media data or metadata.
    </definition>
    <DD_Value_Domain>
      <enumeration_flag>true</enumeration_flag>
      <value_data_type>ASCII_Short_String_Preserved</value_data_type>
      <unit_of_measure_type>Units_of_None</unit_of_measure_type>
      <DD_Permissible_Value>
        <value>Media Handler</value>
        <value_meaning>Indicates that the track contains actual media data, such as video frames, audio samples, 
          or timed text</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Data Handler</value>
        <value_meaning>Indicates that the track serves as a reference or provides a specific way to access data, 
          often used for metadata streams or hint tracks.</value_meaning>
      </DD_Permissible_Value>
    </DD_Value_Domain>
  </DD_Attribute>

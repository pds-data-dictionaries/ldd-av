      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Camera Metadata</value>
        <value_meaning>Camera Motion Metadata Spec (camm)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Metadata</value>

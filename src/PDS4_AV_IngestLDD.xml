      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>IPMP</value>
        <value_meaning>Intellectual Property Management and Protection (ipsm)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>MPEG-7 Stream</value>
        <value_meaning>MPEG-7 textual metadata stream (m7sm)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>NRT Metadata</value>

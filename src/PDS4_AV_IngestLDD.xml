      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Metadata Tags</value>
        <value_meaning>Metadata stored using a structured key-value pair format (mdta)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>MPEG-J</value>
        <value_meaning>Motion JPEG 2000 System handler (mjsm)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Object Content</value>
        <value_meaning>Object Content Info Stream (ocsm)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Object Descriptor</value>
        <value_meaning>Object Descriptor Stream, deticated to MPEG-4 Systems metadata (odsm)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Private</value>
        <value_meaning>Track containing proprietary or custom data (priv)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Scene Description</value>
        <value_meaning>Specialized track defining scene structure, often used for interactive, timed, or animated metadata (sdsm)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Audio Track</value>
        <value_meaning>Audio track (soun)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Text</value>
        <value_meaning>Text track containing subtitles, closed captions, etc (older format, often replaced by subt) (text)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>Time Code</value>
        <value_meaning>Time code track (SMPTE, etc) (tmcd)</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>
        <value>URL</value>
        <value_meaning>Media data referenced externally via a HRL (url )</value_meaning>
      </DD_Permissible_Value>
      <DD_Permissible_Value>

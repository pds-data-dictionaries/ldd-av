    <version_id>1.0</version_id>
    <local_identifier>preferred_rate</local_identifier>
    <nillable_flag>false</nillable_flag>
    <submitter_name>Rafael Alanis</submitter_name>
    <definition>Indicates the intended playback speed of the video.  A value of 1 typically 
      represents normal, real-time speed, while other values can indicate slow motion or 
      fast-forward preferences.
    </definition>
    <DD_Value_Domain>
      <enumeration_flag>false</enumeration_flag>
      <value_data_type>ASCII_Real</value_data_type>
      <unit_of_measure_type>Units_of_None</unit_of_measure_type>
    </DD_Value_Domain>
